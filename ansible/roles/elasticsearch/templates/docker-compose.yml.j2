version: '3.8'

services:
{% for node in es_nodes %}
  {{ node.name }}:
    image: docker.elastic.co/elasticsearch/elasticsearch:{{ es_version }}
    container_name: {{ node.name }}
    environment:
      - node.name={{ node.name }}
      - cluster.name={{ cluster_name }}
      - discovery.seed_hosts={{ es_nodes | map(attribute='name') | join(',') }}
      - cluster.initial_master_nodes={{ es_nodes | map(attribute='name') | join(',') }}
      - bootstrap.memory_lock=true
      - "ES_JAVA_OPTS={{ es_java_opts }}"
      
      - xpack.security.enabled=true
      - ELASTIC_PASSWORD={{ es_password }}
      
      - xpack.security.transport.ssl.enabled=true
      - xpack.security.transport.ssl.verification_mode=certificate
      - xpack.security.transport.ssl.keystore.path=certs/instances.p12
      - xpack.security.transport.ssl.truststore.path=certs/instances.p12
      
      - xpack.security.http.ssl.enabled=true
      - xpack.security.http.ssl.keystore.path=certs/instances.p12
      - xpack.security.http.ssl.truststore.path=certs/instances.p12
    
    ulimits:
      memlock:
        soft: -1
        hard: -1
    
    volumes:
      - {{ node.name }}-data:/usr/share/elasticsearch/data
      - ./certs:/usr/share/elasticsearch/config/certs
    
    ports:
      - "{{ node.port }}:9200"
    
    healthcheck:
      test: ["CMD-SHELL", "curl -k -u elastic:$$ELASTIC_PASSWORD -s https://localhost:9200/_cluster/health | grep -q '\"status\":\"green\"\\|\"status\":\"yellow\"'"]
      interval: 20s
      timeout: 10s
      retries: 5

{% endfor %}

volumes:
{% for node in es_nodes %}
  {{ node.name }}-data:
{% endfor %}
